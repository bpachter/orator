# ─────────────────────────────────────────────────────────────────────────────
# Orator — Environment Variables Reference
# Copy this file to server/.env for local development (git-ignored).
# In production (Railway), set these in the Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── FRED (Federal Reserve Bank of St. Louis) ─────────────────────────────────
# Required. Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── BEA (Bureau of Economic Analysis) ────────────────────────────────────────
# Required for GDP breakdown, corporate profits, personal income panels.
# Register at: https://apps.bea.gov/API/signup/
# Free. ~100 req/min.
BEA_API_KEY=

# ── U.S. Census Bureau ────────────────────────────────────────────────────────
# Required for retail trade by sector, trade in goods, building permits by region.
# Register at: https://api.census.gov/data/key_signup.html
# Free. Essentially unlimited with key.
CENSUS_API_KEY=

# ── EIA (Energy Information Administration) ───────────────────────────────────
# Required for WTI/Brent crude, natural gas, petroleum inventories,
# refinery utilization, electricity prices, rig count.
# Register at: https://www.eia.gov/opendata/register.php
# Free. 5,000 req/hour.
EIA_API_KEY=

# ── Alpha Vantage (Market Prices) ─────────────────────────────────────────────
# Required for equity index prices, sector ETFs, commodity ETFs, FX/DXY.
# Register at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 req/day. Upgrade to premium if needed.
ALPHAVANTAGE_API_KEY=

# ── No-key sources (used automatically, no variable needed) ───────────────────
# Treasury FiscalData:  https://fiscaldata.treasury.gov/api-documentation/
# FRB Data Releases:    https://www.federalreserve.gov/datadownload/
# OECD.Stat:            https://stats.oecd.org/SDMX-JSON/
# ECB SDW:              https://data-api.ecb.europa.eu/
# World Bank:           https://datahelpdesk.worldbank.org/knowledgebase/articles/898581
# BIS:                  https://stats.bis.org/api/v1/
# CBOE VIX/SKEW:        https://www.cboe.com/tradable_products/vix/vix_historical_data/
# IMF:                  https://datahelp.imf.org/knowledgebase/articles/667681

# ── Orator cache config ───────────────────────────────────────────────────────
# Optional. Defaults shown.
# ORATOR_CACHE_TTL=14400       # seconds (4 hours)
# ORATOR_CACHE_PATH=/tmp/orator-cache.sqlite

# ── CORS ──────────────────────────────────────────────────────────────────────
# Optional. Comma-separated list of allowed origins.
# ALLOWED_ORIGINS=https://bpachter.github.io,http://localhost:5173
